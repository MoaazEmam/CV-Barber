
# LLM
LLM_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite-preview
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Session storage
# will add redis later i guess
