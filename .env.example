
LLM_PROVIDER=groq

# Groq (primary) — get keys at https://console.groq.com/keys
# Add more keys separated by commas to increase daily capacity
GROQ_API_KEYS=
GROQ_MODEL=llama-3.3-70b-versatile

# Gemini (fallback) — used automatically when all Groq keys are exhausted/rate-limited
GEMINI_API_KEY=
GEMINI_API_KEYS=
GEMINI_MODEL=gemini-2.5-flash

# ---------------------------------------------------------------------------
# Optional extra free providers. Every provider below is OPTIONAL: it joins the
# fallback chain automatically when its *_API_KEYS is set, and is skipped
# otherwise. With only Groq keys configured the app behaves exactly as before.
#
# Interactive chain (parse/tailor/QA/cover letter):
#   groq → gemini → nvidia → mistral → openrouter → llm7 → zai
# Background chain (auto ATS scoring):
#   cerebras → mistral → groq (small model) → interactive chain
# ---------------------------------------------------------------------------

# Smaller Groq model used by background tasks (shares the Groq keys/quota)
GROQ_SMALL_MODEL=llama-3.1-8b-instant

# Cerebras — https://cloud.cerebras.ai (free ~1M tokens/day)
CEREBRAS_API_KEYS=
CEREBRAS_MODEL=gpt-oss-120b

# NVIDIA NIM — https://build.nvidia.com (free dev tier, ~40 RPM)
NVIDIA_API_KEYS=
NVIDIA_MODEL=nvidia/llama-3.3-nemotron-super-49b-v1

# Mistral — https://console.mistral.ai (free "Experiment" plan, 1B tokens/month)
MISTRAL_API_KEYS=
MISTRAL_MODEL=mistral-large-latest

# OpenRouter — https://openrouter.ai (free models, ~50 req/day)
OPENROUTER_API_KEYS=
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# LLM7 — https://llm7.io (works WITHOUT a key; set LLM7_ENABLED=true to use)
LLM7_ENABLED=false
LLM7_API_KEYS=
LLM7_MODEL=deepseek-r1-0528

# Z AI — https://z.ai/model-api (free GLM Flash models)
ZAI_API_KEYS=
ZAI_MODEL=glm-4.5-flash

# Optional: override chain order (comma-separated provider names)
# LLM_INTERACTIVE_CHAIN=groq,gemini,nvidia,mistral,openrouter,llm7,zai
# LLM_BACKGROUND_CHAIN=cerebras,mistral,groq_small,groq,gemini

# Ollama (used when LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=
OLLAMA_MODEL=

# OCR (scanned/image-only PDF fallback; needs the Tesseract binary installed —
# the Docker image installs it automatically). Disable to skip OCR entirely.
OCR_ENABLED=true
OCR_DPI=300

# Generation
OUTPUT_FORMAT=pdf
TOP_N_PROJECTS=3
TOP_N_EXPERIENCE=3

# Email verification (Brevo — https://app.brevo.com, free 300 emails/day).
# Without BREVO_API_KEY no emails are sent; in development the code is logged.
# MAIL_FROM must be a sender you've verified in Brevo.
BREVO_API_KEY=
MAIL_FROM=
MAIL_FROM_NAME=CV Barber

# Web search (Tavily — https://app.tavily.com, free ~1000 searches/month).
# Powers company research for cover letters/QA and "enrich short job
# description" on the Tailor page. Leave empty to disable both entirely.
TAVILY_API_KEY=
# Per-user limits on /api/enrich-jd (protects the shared Tavily quota).
SEARCH_USER_RATE_LIMITS=5/minute;30/day
# Cached company research is reused for this many days before refreshing.
COMPANY_RESEARCH_TTL_DAYS=30

# Google OAuth login (https://console.cloud.google.com → Credentials).
# Leave empty to disable the "Continue with Google" flow entirely.
# Redirect URI to register in Google: {APP_BASE_URL}/auth/google/callback
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
APP_BASE_URL=http://localhost:8000

# Server
API_HOST=0.0.0.0
API_PORT=8000
ENV=development

DATABASE_URL=
SECRET_KEY=